# CRM (required for enquiry forwarding)
CRM_ENQUIRY_URL=https://your-crm.vercel.app/api/public/enquiry
CRM_ENQUIRY_TOKEN=replace_with_long_random_shared_secret

# Meta Pixel (public ID — safe in the browser)
NEXT_PUBLIC_META_PIXEL_ID=

# Meta Conversions API (server-only — same Pixel ID as above is fine)
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
